<Window x:Class="VAProject.UI.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Assistant Notification" 
        Height="100" Width="350"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False" 
        ShowActivated="False">
    <Border Background="#2D2D30" 
            CornerRadius="12" 
            Margin="10" 
            Padding="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="10" ShadowDepth="3"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Ellipse x:Name="StatusIndicator" 
                     Width="14" Height="14" 
                     Fill="LimeGreen" 
                     VerticalAlignment="Top" 
                     Margin="0,4,15,0"/>

            <TextBlock x:Name="MessageText" 
                       Grid.Column="1" 
                       Text="Listening..." 
                       Foreground="White" 
                       FontFamily="Segoe UI" 
                       FontSize="15" 
                       TextWrapping="Wrap" 
                       VerticalAlignment="Top"/>

            <StackPanel x:Name="SettingsPanel" Grid.Column="1" Margin="0,25,0,0" Visibility="Collapsed">
                <TextBox x:Name="ReminderTimeBox" Background="#3D3D40" Foreground="White" BorderThickness="0" Padding="5" Margin="0,5,0,0"/>
                <Button Content="Зберегти" Width="80" HorizontalAlignment="Right" Margin="0,5,0,0" Background="#007ACC" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>